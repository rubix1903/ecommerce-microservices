# Copy this file to .env and adjust values for local development.
# docker-compose already sets these; this file is only needed when
# running services locally (Option B in the README).

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ecommerce

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Use 29092 when connecting from the host (outside Docker)
KAFKA_BROKERS=localhost:29092

# ── Security ──────────────────────────────────────────────────────────────────
# Change this to a strong random string in any real deployment
JWT_SECRET=change-me-in-production

# ── gRPC service addresses ────────────────────────────────────────────────────
# Use localhost when running services directly (not inside Docker)
USER_SERVICE_ADDR=localhost:50051
PRODUCT_SERVICE_ADDR=localhost:50052
ORDER_SERVICE_ADDR=localhost:50053
PAYMENT_SERVICE_ADDR=localhost:50054

# ── Service ports ─────────────────────────────────────────────────────────────
HTTP_PORT=8080
GRPC_PORT=50051   # Override per-service in each run configuration
