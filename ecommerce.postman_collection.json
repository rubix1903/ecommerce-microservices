{
  "info": {
    "name": "E-Commerce Microservices",
    "description": "Full API collection for the Go microservices e-commerce backend.\n\nFlow:\n1. Run 'Register User'\n2. Run 'Login' — token is auto-saved to {{token}}\n3. Run 'Create Product' — product_id saved to {{product_id}}\n4. Run 'Create Order' — triggers async Kafka payment flow\n5. Check Kafka UI at http://localhost:8090",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080/api/v1" },
    { "key": "token",    "value": "" },
    { "key": "product_id", "value": "" },
    { "key": "order_id",   "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.collectionVariables.set('user_id', json.user_id);",
                  "  console.log('Token saved:', json.token.substring(0, 30) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('product_id', json.id);",
                  "  console.log('Product ID saved:', json.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"MacBook Pro M3\",\n  \"description\": \"16-inch, 36GB RAM, 1TB SSD\",\n  \"price\": 2499.99,\n  \"stock\": 50\n}"
            }
          }
        },
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/products?page=1&limit=10",
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/products/{{product_id}}"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.order_id) {",
                  "  pm.collectionVariables.set('order_id', json.order_id);",
                  "  console.log('Order ID saved:', json.order_id);",
                  "  console.log('Amount:', json.amount);",
                  "  console.log('Status:', json.status);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": \"{{product_id}}\",\n  \"quantity\": 2\n}"
            },
            "description": "Places an order. This triggers: gRPC → product-service (stock deduction) → Kafka publish (order.created) → payment-service processes async → notification-service sends email.\n\nCheck http://localhost:8090 (Kafka UI) to see messages flowing."
          }
        },
        {
          "name": "List My Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/orders?page=1&limit=20",
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/orders/{{order_id}}"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Get Payment by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/payments/{{payment_id}}",
            "description": "Look up a payment by its ID. Payment IDs are returned in order responses and visible in the payment-service logs."
          }
        }
      ]
    },
    {
      "name": "System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "http://localhost:8080/health"
          }
        }
      ]
    }
  ]
}
